# =============================================================================
# Credenciales sensibles — copia este archivo a .env y completa los valores.
# No subas .env al repositorio.
#
# Ciudad, delays, límites de scrape, WhatsApp, Lovable (timeout/headless), mapa,
# plantillas, etc. se configuran en la aplicación: Administración (persistido en BD).
# =============================================================================

# OpenAI — usado por automatizaciones que acceden a ChatGPT vía navegador
OPENAI_EMAIL=tu_email@ejemplo.com
OPENAI_PASSWORD=

# Lovable — cuentas para generar demos (JSON: lista de objetos con email y password)
# Ejemplo: [{"email":"cuenta@ejemplo.com","password":"tu_clave"}]
LOVABLE_ACCOUNTS=[]
