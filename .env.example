# ===========================================
# Configuración del Pipeline de Clientes
# ===========================================
# Copia este archivo como .env y llena los valores

# --- General ---
# Ciudad por defecto para buscar negocios
DEFAULT_CITY=Medellín
# Categorías separadas por coma
DEFAULT_CATEGORIES=gym,restaurante,barbería,spa

# --- OpenAI (ChatGPT via Playwright) ---
# Email y contraseña de tu cuenta OpenAI Pro
OPENAI_EMAIL=tu_email@ejemplo.com
OPENAI_PASSWORD=tu_password

# --- Lovable (6 cuentas free trial) ---
# Las cuentas se configuran en config/accounts.json
# Tiempo maximo (segundos) esperando URL de preview en la UI
LOVABLE_TIMEOUT=180
# false = muestra el navegador (recomendado la primera vez para login en lovable.dev)
LOVABLE_HEADLESS=true

# --- WhatsApp ---
# Número de WhatsApp para enviar mensajes
WHATSAPP_PHONE=3105602568

# --- Rate Limiting ---
# Delay entre mensajes de WhatsApp (segundos)
WHATSAPP_MIN_DELAY=30
WHATSAPP_MAX_DELAY=120
# Máximo de mensajes por día
WHATSAPP_MAX_DAILY=25
# Delay entre scraping de perfiles de IG (segundos)
IG_MIN_DELAY=3
IG_MAX_DELAY=8
